generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "public")]
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  passwordHash  String
  role          Role      @default(CATALOGER)
  avatar        String?
  locale        String    @default("en")
  timezone      String    @default("UTC")
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  assignedTasks Task[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

enum Role {
  SUPER_ADMIN
  ADMIN
  CONTENT_MANAGER
  CATALOGER
  REVIEWER
  FINANCE
  VIEWER
}

model Website {
  id        String    @id @default(cuid())
  name      String
  domain    String    @unique
  platform  String
  apiUrl    String
  apiToken  String
  isActive  Boolean   @default(true)
  products  Product[]
  channels  WebsiteChannel[]
}

// Multi-channel support (website-specific channels)
model WebsiteChannel {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  websiteId   String
  website     Website  @relation(fields: [websiteId], references: [id])
  locales     ChannelLocale[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Locales for multi-language
model Locale {
  id        String   @id @default(cuid())
  code      String   @unique  // e.g. "en_US", "fr_FR", "ar_AE"
  name      String            // e.g. "English (US)"
  label     String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)
  channels  ChannelLocale[]
  productTranslations ProductTranslation[]
  contents  LocalizedContent[]
}

model ChannelLocale {
  id        String         @id @default(cuid())
  channelId String
  channel   WebsiteChannel @relation(fields: [channelId], references: [id])
  localeId  String
  locale    Locale         @relation(fields: [localeId], references: [id])

  @@unique([channelId, localeId])
}

// Product Family (like Akeneo families)
model ProductFamily {
  id              String   @id @default(cuid())
  name            String   @unique
  code            String   @unique
  description     String?
  imageAttribute  String?  // which attribute is the main image
  labelAttribute  String?  // which attribute is used as label
  products        Product[]
  attributes      FamilyAttribute[]
  attributeGroups AttributeGroup[]
  completenessRules CompletenessRule[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Attribute Groups within a Family
model AttributeGroup {
  id              String   @id @default(cuid())
  name            String
  code            String
  familyId        String
  family          ProductFamily @relation(fields: [familyId], references: [id])
  position        Int      @default(0)
  attributes      FamilyAttribute[]
  createdAt       DateTime @default(now())

  @@unique([familyId, code])
}

// Attribute definitions
model Attribute {
  id              String          @id @default(cuid())
  name            String
  code            String          @unique
  label           String?
  type            AttributeType
  group           String          @default("general")
  isRequired      Boolean         @default(false)
  isUnique        Boolean         @default(false)
  isLocalizable   Boolean         @default(false)  // can have different values per locale
  isScopable      Boolean         @default(false)  // can have different values per channel
  validationRule  String?         // regex, url, email, etc.
  validationRegex String?
  validationMin   Float?
  validationMax   Float?
  maxLength       Int?
  allowedValues   Json?           // for select/multiselect types
  options         Json?
  defaultValue    String?
  unit            String?         // measurement unit
  unitFamily      String?         // measurement family (length, weight, etc.)
  measurementFamily String?
  defaultUnit     String?
  tooltip         String?
  sortOrder       Int             @default(0)
  position        Int             @default(0)
  families        FamilyAttribute[]
  values          ProductAttributeValue[]
  ruleConditions  RuleCondition[]
  ruleActions     RuleAction[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum AttributeType {
  TEXT
  TEXTAREA
  RICH_TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
  MULTI_SELECT
  PRICE
  METRIC
  IMAGE
  FILE
  URL
  COLOR
  IDENTIFIER
}

// Join table: which attributes belong to which family group
model FamilyAttribute {
  id              String         @id @default(cuid())
  familyId        String
  family          ProductFamily  @relation(fields: [familyId], references: [id], onDelete: Cascade)
  attributeId     String
  attribute       Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  groupId         String?
  group           AttributeGroup? @relation(fields: [groupId], references: [id])
  isRequired      Boolean        @default(false)
  channel         String?
  sortOrder       Int            @default(0)
  position        Int            @default(0)

  @@unique([familyId, attributeId])
}

// Completeness rules per family
model CompletenessRule {
  id            String        @id @default(cuid())
  familyId      String
  family        ProductFamily @relation(fields: [familyId], references: [id])
  channelCode   String
  localeCode    String
  requiredFields Json          // array of attribute codes that must be filled
  createdAt     DateTime      @default(now())

  @@unique([familyId, channelCode, localeCode])
}

// Product catalog
model Product {
  id              String          @id @default(cuid())
  sku             String          @unique
  websiteId       String
  website         Website         @relation(fields: [websiteId], references: [id])
  categoryId      String?
  category        Category?       @relation(fields: [categoryId], references: [id])
  familyId        String?
  family          ProductFamily?  @relation(fields: [familyId], references: [id])
  brand           String?
  status          ProductStatus   @default(DRAFT)
  priority        Priority        @default(MEDIUM)
  completeness    Float           @default(0)  // 0-100 percentage
  completenessScore Int           @default(0)

  // Product type for variants
  productType     ProductType     @default(SIMPLE)
  parentId        String?
  parent          Product?        @relation("ProductVariants", fields: [parentId], references: [id])
  variants        Product[]       @relation("ProductVariants")
  isVariant       Boolean         @default(false)
  variantAxis     Json?           // e.g. ["color", "size"]

  // Raw data from ERP/import
  rawTitle        String?
  rawDescription  String?
  rawSpecs        Json?

  // AI-generated content
  aiTitle         String?
  aiMetaTitle     String?
  aiMetaDesc      String?
  aiShortDesc     String?
  aiLongDesc      String?
  aiSpecs         Json?
  aiFaqs          Json?
  aiSchemaMarkup  Json?
  aiModel         String?
  aiGeneratedAt   DateTime?
  aiQualityScore  Float?          // AI-assessed quality score

  // Approved/published content
  title           String?
  metaTitle       String?
  metaDesc        String?
  shortDesc       String?
  longDesc        String?
  specs           Json?
  faqs            Json?
  schemaMarkup    Json?

  // Pricing
  costPrice       Decimal?
  sellingPrice    Decimal?
  marginPct       Decimal?
  currency        String          @default("INR")

  // Data quality
  qualityScore    Float           @default(0)  // 0-100

  // Sync
  magentoId       String?
  lastSyncedAt    DateTime?
  syncStatus      SyncStatus      @default(PENDING)

  images          ProductImage[]
  tasks           Task[]
  auditLogs       AuditLog[]
  embedding       ProductEmbedding?
  attributeValues ProductAttributeValue[]
  translations    ProductTranslation[]
  localizedContent LocalizedContent[]
  associations    ProductAssociation[]    @relation("SourceProduct")
  associatedFrom  ProductAssociation[]    @relation("TargetProduct")
  associationsFrom ProductAssociation[]   @relation("AssocFrom")
  associationsTo   ProductAssociation[]   @relation("AssocTo")

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

enum ProductType {
  SIMPLE
  VARIANT
  MODEL
  GROUPED
  BUNDLE
}

enum ProductStatus {
  DRAFT
  AI_GENERATED
  IN_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SyncStatus {
  PENDING
  SYNCED
  FAILED
  SKIPPED
}

// Dynamic attribute values for products
model ProductAttributeValue {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId   String
  attribute     Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  locale        String?
  channel       String?
  localeCode    String?   // null if not localizable
  channelCode   String?   // null if not scopable
  textValue     String?   @db.Text
  valueText     String?   @db.Text
  numberValue   Float?
  valueNumber   Decimal?
  booleanValue  Boolean?
  valueBoolean  Boolean?
  dateValue     DateTime?
  valueDate     DateTime?
  jsonValue     Json?     // for multiselect, price collections, etc.
  valueJson     Json?
  mediaUrl      String?   // for image/file types
  unit          String?   // for metric type
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([productId, attributeId, localeCode, channelCode])
}

// Multi-language product content
model ProductTranslation {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  localeId      String
  locale        Locale   @relation(fields: [localeId], references: [id])
  title         String?
  metaTitle     String?
  metaDesc      String?
  shortDesc     String?
  longDesc      String?  @db.Text
  specs         Json?
  faqs          Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([productId, localeId])
}

// Product associations (cross-sell, up-sell, etc.)
model ProductAssociation {
  id              String          @id @default(cuid())
  sourceProductId String
  sourceProduct   Product         @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProductId String
  targetProduct   Product         @relation("TargetProduct", fields: [targetProductId], references: [id], onDelete: Cascade)
  fromId          String
  from            Product         @relation("AssocFrom", fields: [fromId], references: [id], onDelete: Cascade)
  toId            String
  to              Product         @relation("AssocTo", fields: [toId], references: [id], onDelete: Cascade)
  type            AssociationType
  sortOrder       Int             @default(0)
  position        Int             @default(0)
  createdAt       DateTime        @default(now())

  @@unique([sourceProductId, targetProductId, type])
  @@unique([fromId, toId, type])
}

enum AssociationType {
  CROSS_SELL
  UP_SELL
  UPSELL
  SUBSTITUTION
  SUBSTITUTE
  PACK
  ACCESSORY
  SIMILAR
}

// Enrichment rules engine
model EnrichmentRule {
  id          String     @id @default(cuid())
  name        String
  description String?
  priority    Int        @default(0)
  isActive    Boolean    @default(true)
  conditions  Json       // e.g. [{"field": "brand", "operator": "equals", "value": "X"}]
  actions     Json       // e.g. [{"type": "set_value", "field": "category", "value": "Y"}]
  runCount    Int        @default(0)
  lastRunAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

// Measurement families & units
model MeasurementFamily {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique   // e.g. "length", "weight", "volume"
  label       String?
  standardUnit String             // e.g. "meter", "kilogram"
  units       MeasurementUnit[]
}

model MeasurementUnit {
  id               String            @id @default(cuid())
  name             String
  code             String
  symbol           String
  label            String?
  familyId         String
  family           MeasurementFamily @relation(fields: [familyId], references: [id], onDelete: Cascade)
  convertTo        Float             @default(1)  // multiplier to convert to standard unit
  conversionFactor Decimal           @default(1)

  @@unique([familyId, code])
}

// Notifications
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   // "task_assigned", "review_needed", "ai_complete", "sync_failed", etc.
  title     String
  message   String
  data      Json?
  link      String?  // URL to navigate to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Category {
  id               String          @id @default(cuid())
  name             String
  slug             String          @unique
  description      String?
  icon             String?
  parentId         String?
  parent           Category?       @relation("CategoryTree", fields: [parentId], references: [id])
  children         Category[]      @relation("CategoryTree")
  promptTemplateId String?
  promptTemplate   PromptTemplate? @relation(fields: [promptTemplateId], references: [id])
  products         Product[]
  position         Int             @default(0)
}

model ProductImage {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  altText    String?
  caption    String?
  tags       Json?    // e.g. ["lifestyle", "front-view"]
  width      Int?
  height     Int?
  fileSize   Int?
  mimeType   String?
  position   Int      @default(0)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model PromptTemplate {
  id             String     @id @default(cuid())
  name           String
  version        Int        @default(1)
  isActive       Boolean    @default(true)
  titlePrompt    String     @db.Text
  descPrompt     String     @db.Text
  specsPrompt    String     @db.Text
  faqPrompt      String     @db.Text
  seoPrompt      String     @db.Text
  preferredModel String     @default("claude")
  categories     Category[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model Task {
  id           String     @id @default(cuid())
  productId    String
  product      Product    @relation(fields: [productId], references: [id])
  assignedToId String?
  assignedTo   User?      @relation(fields: [assignedToId], references: [id])
  type         TaskType
  status       TaskStatus @default(PENDING)
  priority     Priority   @default(MEDIUM)
  notes        String?
  dueDate      DateTime?
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

enum TaskType {
  ENRICH_CONTENT
  REVIEW_CONTENT
  APPROVE_PRICING
  UPLOAD_IMAGES
  PUBLISH
  TRANSLATE
  QUALITY_CHECK
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

model AuditLog {
  id         String   @id @default(cuid())
  productId  String?
  product    Product? @relation(fields: [productId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entity     String?  // "product", "category", "family", etc.
  entityId   String?
  field      String?
  oldValue   String?  @db.Text
  newValue   String?  @db.Text
  metadata   Json?
  createdAt  DateTime @default(now())
}

model ProductEmbedding {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id])
  embedding Unsupported("vector(1536)")?
}

// ============================================================
// NEW MODELS
// ============================================================

// Multi-language support (localized content per product)
model LocalizedContent {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  localeId    String
  locale      Locale   @relation(fields: [localeId], references: [id])
  title       String?
  metaTitle   String?
  metaDesc    String?
  shortDesc   String?
  longDesc    String?  @db.Text
  specs       Json?
  faqs        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, localeId])
}

// Rules Engine
model Rule {
  id          String          @id @default(cuid())
  name        String
  description String?
  priority    Int             @default(0)
  isActive    Boolean         @default(true)
  conditions  RuleCondition[]
  actions     RuleAction[]
  lastRunAt   DateTime?
  runCount    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model RuleCondition {
  id          String    @id @default(cuid())
  ruleId      String
  rule        Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  attributeId String?
  attribute   Attribute? @relation(fields: [attributeId], references: [id])
  field       String
  operator    String
  value       String
  locale      String?
  channel     String?
  sortOrder   Int       @default(0)
}

model RuleAction {
  id          String    @id @default(cuid())
  ruleId      String
  rule        Rule      @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  type        RuleActionType
  attributeId String?
  attribute   Attribute? @relation(fields: [attributeId], references: [id])
  field       String?
  value       String?
  locale      String?
  channel     String?
  sortOrder   Int       @default(0)
}

enum RuleActionType {
  SET_VALUE
  COPY_VALUE
  CLEAR_VALUE
  ADD_CATEGORY
  REMOVE_CATEGORY
  SET_FAMILY
  SET_STATUS
  CALCULATE
  CONCATENATE
}

// Data Quality
model QualityRule {
  id          String   @id @default(cuid())
  name        String
  type        String
  field       String
  condition   String
  value       String?
  severity    String   @default("warning")
  message     String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

// Channel/Scope (for multi-channel content)
model Channel {
  id          String   @id @default(cuid())
  code        String   @unique
  label       String
  currencies  Json?
  locales     Json?
  categoryTree String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}
